# Задача 1. Числа Фибоначчи с хранением в массиве, оценка пространственной сложности.

while True:
    try:
        n = int(input("Введите неотрицательное целое n: "))
        if n < 0:
            print("Ошибка! Число должно быть неотрицательным")
            continue
        break
    except ValueError:
        print("Ошибка! Введите целое число")

# Вариант 1: с массивом O(n) памяти
def fib_arr(n):
    if n == 0: return 0
    if n == 1: return 1
    arr = [0] * (n + 1)
    arr[0] = 0
    arr[1] = 1
    for i in range(2, n + 1):
        arr[i] = arr[i-1] + arr[i-2]
    return arr[n]

# Вариант 2: с двумя переменными O(1) памяти
def fib(n):
    if n == 0: return 0
    if n == 1: return 1
    a, b = 0, 1
    for i in range(2, n + 1):
        a, b = b, a + b
    return b

print(f"F({n}) = {fib_arr(n)} (с массивом)")
print(f"F({n}) = {fib(n)} (с двумя переменными)")
print("\n=== Анализ сложности ===")
print("Алгоритм с массивом:")
print("  Временная сложность: O(n)")
print("  Доп. простр. сложность: O(n) — массив из n+1 элементов")
print("\nАлгоритм с двумя переменными:")
print("  Временная сложность: O(n)")
print("  Доп. простр. сложность: O(1) — только две переменные")
print("\n=== Компромисс между памятью и сложностью реализации ===")
