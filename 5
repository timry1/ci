# Задача 21. Сбалансированные скобки с поддержкой трёх типов: (), [], {}

def b(s):
    """
    Проверяет, сбалансированы ли скобки в строке
    Возвращает (результат, количество операций со стеком)
    """
    stack = []
    op = 0
    
    # Словарь соответствия закрывающих скобок открывающим
    pairs = {')': '(', ']': '[', '}': '{'}
    
    for char in s:
        if char in '([{':  # открывающая скобка
            stack.append(char)
            op += 1  # операция добавления в стек
        elif char in ')]}':  # закрывающая скобка
            op += 1  # операция проверки стека
            if not stack:  # стек пуст, закрывать нечего
                return False, op
            if stack[-1] == pairs[char]:  # правильная пара
                stack.pop()
                op += 1  # операция удаления из стека
            else:  # неправильная пара
                return False, op
    
    # В конце стек должен быть пуст
    op += 1  # финальная проверка
    return len(stack) == 0, op

# Проверка 5 различных строк
test_strings = [
    "()",                    # правильная
    "()[]{}",               # правильная
    "([{}])",               # правильная
    "([)]",                 # неправильная
    "((()))",               # правильная
]

print(" Проверка сбалансированности скобок: \n")

for i, s in enumerate(test_strings, 1):
    balanced, ops = b(s)
    status = "+ сбалансировано" if balanced else "- несбалансировано"
    print(f"{i}. Строка: '{s}'")
    print(f"   Результат: {status}")
    print(f"   Операций со стеком: {ops}")
    print()
print("Анализ сложности:")
print("Временная сложность: O(n) — проходим по строке один раз")
print("Пространственная сложность: O(n) — в худшем случае стек содержит n/2 элементов")
print("Каждый символ обрабатывается 1 раз, операции со стеком: push/pop за O(1)")
